# Server Environment Variables
NODE_ENV=development
PORT=5000

# MongoDB
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/karigar?retryWrites=true&w=majority

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=1h
JWT_REFRESH_SECRET=your-refresh-secret-key
JWT_REFRESH_EXPIRES_IN=30d

# Client URL (for CORS) — comma-separated for multiple origins
CLIENT_URL=http://localhost:8080,https://your-frontend.vercel.app

# Nodemailer (Gmail App Password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-char-app-password
EMAIL_FROM=Karigar <noreply@karigar.com>

# Admin (receives account + payment notifications)
ADMIN_EMAIL=karigarcareers@gmail.com

# Bank transfer details shown to students on the payment page (manual transfer + receipt upload).
# Supports multiple accounts — add PAYMENT_ACCOUNT_1_*, PAYMENT_ACCOUNT_2_*, etc. Students pay to any one.
PAYMENT_ACCOUNT_1_BANK=
PAYMENT_ACCOUNT_1_TITLE=
PAYMENT_ACCOUNT_1_NUMBER=
PAYMENT_ACCOUNT_1_IBAN=
# PAYMENT_ACCOUNT_2_BANK=
# PAYMENT_ACCOUNT_2_TITLE=
# PAYMENT_ACCOUNT_2_NUMBER=
# PAYMENT_ACCOUNT_2_IBAN=
PAYMENT_NOTE=Please transfer the exact amount and upload your receipt. Your session is confirmed after we verify the payment.

# Google Sign-In (OAuth 2.0 Web client ID — same value as frontend VITE_GOOGLE_CLIENT_ID)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
# Google Calendar auto-add (OAuth client SECRET, from the SAME OAuth client as above).
# Also: enable the "Google Calendar API" in the Cloud project, add the calendar.events
# scope to the consent screen, and register this redirect URI on the OAuth client:
#   <SERVER_URL>/api/auth/google/calendar/callback
GOOGLE_CLIENT_SECRET=your-oauth-client-secret
# Public base URL of THIS backend (used to build the Google Calendar redirect URI).
SERVER_URL=http://localhost:5000

# Account verification OTP is sent via EMAIL (uses the SMTP settings above). No SMS provider needed.

# Video calls — Jitsi as a Service (JaaS / 8x8). Blank = fall back to public meet.jit.si (demo limits).
# Private key: paste the PEM on one line with \n for newlines, e.g. "-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----"
JAAS_APP_ID=vpaas-magic-cookie-xxxxxxxxxxxxxxxx
JAAS_API_KEY_ID=vpaas-magic-cookie-xxxxxxxxxxxxxxxx/xxxxxx
# Provide the private key EITHER as a file path (local dev) ...
JAAS_PRIVATE_KEY_PATH=jaas-private.pem
# ... OR inline (e.g. on Vercel, paste the PEM; newlines or \n both fine)
JAAS_PRIVATE_KEY=

# Cron endpoint secret — protects GET /api/cron (auto-complete ended sessions +
# send session reminders). On serverless (Vercel) node-cron does not run, so an
# external scheduler (e.g. cron-job.org) pings /api/cron?key=<this-secret> every
# ~10 min. Use a long random string. Leave blank locally to leave the endpoint open.
CRON_SECRET=

# Seed credentials
SEED_ADMIN_EMAIL=admin@karigar.com
SEED_ADMIN_PASSWORD=Admin@12345
SEED_MENTOR_PASSWORD=Mentor@12345
SEED_STUDENT_PASSWORD=Student@12345
