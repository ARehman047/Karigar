# Frontend environment variables (Vite exposes only VITE_* to the client)

# Base URL of the Karigar backend API.
# Local dev:  http://localhost:5000/api
# Production: https://<your-backend>.vercel.app/api
VITE_API_URL=http://localhost:5000/api

# App name (optional)
VITE_APP_NAME=Karigar

# Google Sign-In (OAuth 2.0 Web client ID — same value as backend GOOGLE_CLIENT_ID)
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
